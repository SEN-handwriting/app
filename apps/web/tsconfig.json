{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "./src",
    "paths": {
      "#auth/*": ["features/auth/*"],
      "#maps/*": ["features/maps/*"],
      "#game/*": ["features/game/*"],
      "#party/*": ["features/party/*"],
      "#search/*": ["features/search/*"],
      "#chat/*": ["features/chat/*"],
      "#/*": ["*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
